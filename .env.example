# Supabase — Obtenha essas chaves no dashboard do Supabase (Settings > API)
VITE_SUPABASE_URL="https://seu-projeto.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-chave-anon-aqui"
VITE_SUPABASE_PROJECT_ID="seu-project-id-aqui"

# Upstash Redis — OPCIONAL (usado pela Edge Function registrar-ponto-v2)
# Se não configurado, a função usa fallback automático com Postgres.
# Crie em https://console.upstash.com e adicione nos Secrets do Supabase
# (Supabase Dashboard > Settings > Edge Functions > Secrets)
# UPSTASH_REDIS_REST_URL="https://seu-endpoint.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="seu-token-aqui"
